{
  "imports": {
    "data_processing": [
      "pandas",
      "numpy"
    ],
    "data_collection": [
      "yfinance"
    ],
    "technical_indicators": [
      "RSIIndicator",
      "MACD",
      "EMAIndicator",
      "BollingerBands"
    ],
    "machine_learning": [
      "RandomForestClassifier",
      "train_test_split",
      "accuracy_score"
    ],
    "model_saving": [
      "joblib"
    ]
  },
  "stocks": [
    "AAPL",
    "MSFT",
    "GOOGL",
    "AMZN",
    "TSLA"
  ],
  "data_download": {
    "source": "Yahoo Finance",
    "start_date": "2020-01-01",
    "end_date": "2025-01-01"
  },
  "technical_features": {
    "RSI": "Relative Strength Index",
    "MACD": "Moving Average Convergence Divergence",
    "EMA": "Exponential Moving Average",
    "BB_High": "Bollinger Band Upper",
    "BB_Low": "Bollinger Band Lower"
  },
  "risk_features": {
    "Daily_Return": "Percentage daily return",
    "Volatility": "(High - Low) / Close",
    "Volume_Change": "Percentage volume change"
  },
  "target_creation": {
    "future_days": 5,
    "target_logic": "Future_Close > Current_Close",
    "target_type": "Binary Classification"
  },
  "stock_encoding": {
    "method": "Category Encoding",
    "column_name": "Stock_Code"
  },
  "features_used": [
    "RSI",
    "MACD",
    "EMA",
    "BB_High",
    "BB_Low",
    "Volume",
    "Daily_Return",
    "Volatility",
    "Volume_Change",
    "Stock_Code"
  ],
  "train_test_split": {
    "test_size": 0.2,
    "random_state": 42
  },
  "model": {
    "type": "RandomForestClassifier",
    "parameters": {
      "n_estimators": 200,
      "max_depth": 8,
      "min_samples_split": 10,
      "min_samples_leaf": 5,
      "random_state": 42
    }
  },
  "evaluation": {
    "metric": "accuracy_score"
  },
  "model_output": {
    "file_name": "stock_model.pkl",
    "save_method": "joblib.dump"
  },
  "workflow": [
    "Download stock data",
    "Calculate technical indicators",
    "Create risk features",
    "Generate future target",
    "Encode stock names",
    "Train RandomForest model",
    "Evaluate accuracy",
    "Save trained model"
  ]
}
